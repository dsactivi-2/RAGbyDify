# ============================================================
# RAGbyDify — Environment Variables
# ============================================================
# Kopiere diese Datei nach .env und fuelle die Werte aus:
#   cp .env.example .env
#
# NIEMALS .env in Git committen! (.gitignore prueft das)
# ============================================================

# --- Telegram Bot ---
TELEGRAM_TOKEN=           # Neuen Token bei @BotFather holen: /revoke + /newbot oder /token

# --- Dify API ---
DIFY_API_URL=http://localhost:3080/v1
DIFY_API_KEY=             # Dify UI → Settings → API Keys → Create new

# --- Dify Knowledge Base ---
DIFY_KB_ID=               # Dify UI → Knowledge → Dataset → ID aus URL kopieren
DIFY_KB_KEY=              # Dify UI → Knowledge → Dataset → API Key

# --- HippoRAG ---
HIPPORAG_URL=http://localhost:8001/knowledge/query

# --- Mem0 (Self-Learning) ---
MEM0_API_KEY=             # https://app.mem0.ai → Settings → API Keys → Regenerate
MEM0_ORG_ID=              # https://app.mem0.ai → Settings → Organization ID
MEM0_PROJECT_ID=          # https://app.mem0.ai → Settings → Project ID

# --- RAG Tuning (optional) ---
RAG_TIMEOUT=10
RAG_KB_TOP_K=5
RAG_HIPPO_TOP_K=5
